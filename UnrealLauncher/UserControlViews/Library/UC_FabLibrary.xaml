<UserControl x:Class="UnrealLauncher.UserControlViews.Library.UC_FabLibrary"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:UnrealLauncher.UserControlViews.Library"
             mc:Ignorable="d" 
             d:DesignHeight="88" d:DesignWidth="344">

        <Border Background="{StaticResource CardBackgroundBrush}"
            BorderBrush="{StaticResource CardBorderBrush}"
            BorderThickness="1"
            Padding="10,8">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="76"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- IMAGE -->
                <Grid Grid.Column="0"
                  Width="76"
                  Height="43"
                  VerticalAlignment="Center">

                    <Border CornerRadius="2" ClipToBounds="True">
                    <Image Source="{Binding ImagePath}"
                           Stretch="Fill"/>
                    </Border>

                    <Button Style="{StaticResource FabInfoButtonStyle}"
                        Content="i"
                         Command="{Binding DataContext.OpenLinkCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                         CommandParameter="{Binding}"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        Margin="0,0,-8,-8"/>
                </Grid>

                <!-- TEXTE + BOUTONS -->
                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                           Text="{Binding Name}"
                           Foreground="{StaticResource TitleBrush}"
                           FontSize="14"
                           TextTrimming="CharacterEllipsis"
                           VerticalAlignment="Center"/>

                    <Grid Grid.Row="2" HorizontalAlignment="Left">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="34"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                            Content="Add To Project"
                            Style="{StaticResource FabPrimaryButtonStyle}"
                            Command="{Binding AddToProjectCommand}"
                            Height="34"
                            MinWidth="118"/>

                        <ToggleButton Grid.Column="1"
                                  Style="{StaticResource FabArrowButtonStyle}"
                                  Margin="1,0,0,0"
                                  IsChecked="{Binding IsMenuOpen, Mode=TwoWay}"/>

                        <Popup PlacementTarget="{Binding ElementName=ArrowAnchor}"
                           Placement="Bottom"
                           StaysOpen="False"
                           IsOpen="{Binding IsMenuOpen, Mode=TwoWay}"
                           AllowsTransparency="True">
                            <Border Background="#1C1C1C"
                                BorderBrush="#2E2E2E"
                                BorderThickness="1"
                                Padding="4"
                                MinWidth="170">
                                <StackPanel>
                                    <Button Content="Add To Project"
                                        Command="{Binding AddToProjectCommand}"
                                        Background="Transparent"
                                        Foreground="White"
                                        BorderThickness="0"
                                        HorizontalContentAlignment="Left"
                                        Padding="10,8"
                                        Cursor="Hand"/>

                                    <Button Content="View Details"
                                        Command="{Binding ViewDetailsCommand}"
                                        Background="Transparent"
                                        Foreground="White"
                                        BorderThickness="0"
                                        HorizontalContentAlignment="Left"
                                        Padding="10,8"
                                        Cursor="Hand"/>

                                    <Button Content="Show In Fab"
                                        Command="{Binding OpenFabCommand}"
                                        Background="Transparent"
                                        Foreground="White"
                                        BorderThickness="0"
                                        HorizontalContentAlignment="Left"
                                        Padding="10,8"
                                        Cursor="Hand"/>
                                </StackPanel>
                            </Border>
                        </Popup>

                        <!-- ancre pour popup -->
                        <Border x:Name="ArrowAnchor"
                            Grid.ColumnSpan="2"
                            Background="Transparent"/>
                    </Grid>
                </Grid>
            </Grid>
        </Border>
    </UserControl>
