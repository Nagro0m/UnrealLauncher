<UserControl x:Class="UnrealLauncher.UserControlViews.Library.UC_MyProjects"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:UnrealLauncher.UserControlViews.Library"
             mc:Ignorable="d" 
             d:DesignHeight="180" d:DesignWidth="120">
    <UserControl.Resources>
        <Style x:Key="ProjectCardButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="RootBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Stretch"
                                              VerticalAlignment="Stretch"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RootBorder" Property="BorderBrush" Value="#D6C200"/>
                                <Setter TargetName="RootBorder" Property="BorderThickness" Value="2"/>
                                <Setter Property="Background" Value="#1A1D24"></Setter>
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="RootBorder" Property="Opacity" Value="0.9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Button Style="{StaticResource ProjectCardButtonStyle}"
            CommandParameter="{Binding}">
        <Button.InputBindings>
            <MouseBinding Gesture="LeftDoubleClick"
                      Command="{Binding DataContext.LaunchCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                      CommandParameter="{Binding}" />
        </Button.InputBindings>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="4*"/>
                <RowDefinition Height="1*"/>
            </Grid.RowDefinitions>

            <!-- Partie image -->
            <Border Grid.Row="0"
                    Background="Transparent"
                    BorderBrush="Transparent"
                    BorderThickness="1">
                <Grid Margin="8">
                    <Image Source="{Binding ImagePath}"
                           Stretch="Uniform"/>
                    <TextBlock Text="{Binding EngineVersion}"
                               Foreground="White"
                               FontSize="15"
                               HorizontalAlignment="Right" VerticalAlignment="Bottom" 
                               Background="#E5000000"/>
                </Grid>
                
            </Border>

            <!-- Texte -->
            <StackPanel Grid.Row="1"
                        Margin="8,0,8,8">

                <TextBlock Text="{Binding Name}"
                           Foreground="#D7D9DD"
                           FontSize="15"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           MaxHeight="30"/>
            </StackPanel>
        </Grid>
    </Button>
</UserControl>
