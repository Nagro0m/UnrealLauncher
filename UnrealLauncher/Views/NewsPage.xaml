<Page x:Class="UnrealLauncher.Views.NewsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:UnrealLauncher.Views"
      xmlns:sys="clr-namespace:System;assembly=mscorlib"
      mc:Ignorable="d" 
      d:DesignHeight="955" d:DesignWidth="1684"
      Title="NewsPage">
    <Page.Resources>
        <Style TargetType="Grid" x:Key="BackgroundColor">
            <Setter Property="Background" Value="#121212"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="Transparent"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="#666666"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>
    
    <Grid Style="{StaticResource BackgroundColor}">
        <ScrollViewer VerticalScrollBarVisibility="Auto">

            <StackPanel MaxWidth="1920" Margin="10,10,10,10">

                <Border Margin="10,10,10,20"
        MaxWidth="1000"
        HorizontalAlignment="Center">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.5*"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                ClipToBounds="True"
                MinHeight="200">

                            <Image Source="https://cms-assets.unrealengine.com/AiKUh5PQCTaOFnmJDZJBfz/resize=width:1200/cmhf5b24228da07o4lqbhp7tz"
                   Stretch="UniformToFill"/>
                        </Border>

                        <Border Grid.Column="1"
                Background="#2D2D2D"
                Padding="15">

                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Unreal Engine 5.7 is available now!"
                           FontSize="20"
                           FontWeight="Bold"
                           Foreground="White"
                           TextWrapping="Wrap"/>
                                <TextBlock Text="Build expansive, lifelike worlds filled with rich, beautiful details in real time; render high-fidelity layered and blended materials; light complex worlds like never before; and enjoy smoother and more intuitive animation and rigging workflows. Plus, get instant guidance from the new in-editor Al Assistant.Check-out the full release notes for more details."
                           Margin="0,10,0,0"
                           Foreground="#AAAAAA"
                           TextWrapping="Wrap"/>
                            </StackPanel>

                        </Border>
                    </Grid>
                </Border>
                
                <Grid>
                    <StackPanel Orientation="Horizontal"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Margin="10">

                        <Button Margin="5" Padding="10,5" Background="#00DDDDDD" BorderBrush="#00707070" Command="{Binding NewsCommand}">
                            <StackPanel Orientation="Horizontal">
                                <Image Source="/Data/Image/Icon/NewsIcon.png" Width="16" Height="16" Margin="0,0,5,0"/>
                                <TextBlock Text="News" Foreground="#FFB3B3B3"/>
                            </StackPanel>
                        </Button>

                        <Button Margin="5" Padding="10,5" Background="#00DDDDDD" BorderBrush="#00707070" Command="{Binding YoutubeCommand}">
                            <StackPanel Orientation="Horizontal">
                                <Image Source="/Data/Image/Icon/GlobeIcon.png" Width="16" Height="16" Margin="0,0,5,0"/>
                                <TextBlock Text="YouTube" Foreground="#FFB3B3B3"/>
                            </StackPanel>
                        </Button>

                        <Button Margin="5" Padding="10,5" Background="#00DDDDDD" BorderBrush="#00707070" Command="{Binding QACommand}">
                            <StackPanel Orientation="Horizontal">
                                <Image Source="/Data/Image/Icon/LightIcon.png" Width="16" Height="16" Margin="0,0,5,0"/>
                                <TextBlock Text="Q&amp;A" Foreground="#FFB3B3B3"/>
                            </StackPanel>
                        </Button>

                        <Button Margin="5" Padding="10,5" Background="#00DDDDDD" BorderBrush="#00707070" Command="{Binding ForumsCommand}">
                            <StackPanel Orientation="Horizontal">
                                <Image Source="/Data/Image/Icon/ForumsIcon.png" Width="16" Height="16" Margin="0,0,5,0"/>
                                <TextBlock Text="Forums" Foreground="#FFB3B3B3"/>
                            </StackPanel>
                        </Button>

                        <Button Margin="5" Padding="10,5" Background="#00DDDDDD" BorderBrush="#00707070" Command="{Binding RoadmapCommand}">
                            <StackPanel Orientation="Horizontal">
                                <Image Source="/Data/Image/Icon/MapIcon.png" Width="16" Height="16" Margin="0,0,5,0"/>
                                <TextBlock Text="Roadmap" Foreground="#FFB3B3B3"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>

                    <StackPanel>

                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width=".5*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,20,0">
                                <TextBlock Text="Featured Content"
                       FontSize="18"
                       FontWeight="Bold"
                       Foreground="White"
                       Margin="5,0,0,10"/>

                                <Border Height="2" Background="#F5A623" Margin="5,0,0,10"/>

                                <ItemsControl ItemsSource="{Binding FeaturedItems}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Columns="2"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>

                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Command="{Binding DataContext.ItemClickCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                CommandParameter="{Binding Link}"
                                Background="Transparent"
                                BorderThickness="0"
                                Padding="0"
                                Cursor="Hand">
                                                <Border Margin="5"
                                    Background="#2D2D2D"
                                    CornerRadius="6"
                                    ClipToBounds="True">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="#2D2D2D"/>
                                                            <Style.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter Property="Background" Value="#3A3A3A"/>
                                                                </Trigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <Grid>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="220"/>
                                                            <RowDefinition Height="*"/>
                                                        </Grid.RowDefinitions>

                                                        <Border Grid.Row="0" ClipToBounds="True">
                                                            <Image Source="{Binding Image}" Stretch="UniformToFill"/>
                                                        </Border>

                                                        <Border Grid.Row="0"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Top"
                                            Background="#F5A623"
                                            CornerRadius="4"
                                            Padding="8,4"
                                            Margin="10">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsSale}" Value="True">
                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock Text="★ " Foreground="White" FontWeight="Bold" FontSize="11"/>
                                                                <TextBlock Text="Sale!" Foreground="White" FontWeight="Bold" FontSize="11"/>
                                                            </StackPanel>
                                                        </Border>

                                                        <Grid Grid.Row="1">
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="*"/>
                                                                <RowDefinition Height="Auto"/>
                                                            </Grid.RowDefinitions>

                                                            <StackPanel Margin="14,12,14,8">
                                                                <TextBlock Text="{Binding Title}"
                                                       Foreground="White"
                                                       FontWeight="Bold"
                                                       FontSize="16"
                                                       TextWrapping="Wrap"
                                                       Margin="0,0,0,6"/>
                                                                <TextBlock Text="{Binding Description}"
                                                       Foreground="#AAAAAA"
                                                       FontSize="12"
                                                       TextWrapping="Wrap"
                                                       MaxHeight="50"/>
                                                            </StackPanel>

                                                            <Border Grid.Row="1"
                                                Background="#222222"
                                                Padding="14,8">
                                                                <Grid>
                                                                    <TextBlock Text="{Binding Source}"
                                                           Foreground="#888888"
                                                           FontSize="11"
                                                           VerticalAlignment="Center"/>
                                                                    <TextBlock Text="&#x29C9;"
                                                           Foreground="#888888"
                                                           FontSize="14"
                                                           HorizontalAlignment="Right"
                                                           VerticalAlignment="Center"/>
                                                                </Grid>
                                                            </Border>
                                                        </Grid>
                                                    </Grid>
                                                </Border>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>

                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Weekly Spotlights"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   Margin="5,0,0,10"/>

                                <Border Height="2" Background="#F5A623" Margin="5,0,0,10"/>

                                <ItemsControl ItemsSource="{Binding SpotlightItems}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Command="{Binding DataContext.ItemClickCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding Link}"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Padding="0"
                                                Cursor="Hand">
                                                <Border Margin="5"
                                                    CornerRadius="6"
                                                    ClipToBounds="True"
                                                    Height="160">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="#2D2D2D"/>
                                                            <Style.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter Property="Background" Value="#3A3A3A"/>
                                                                </Trigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <Grid>
                                                        <Image Source="{Binding Image}"
                                           Stretch="UniformToFill"/>

                                                        <Border VerticalAlignment="Bottom">
                                                            <Border.Background>
                                                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                                    <GradientStop Color="Transparent" Offset="0"/>
                                                                    <GradientStop Color="#CC000000" Offset="1"/>
                                                                </LinearGradientBrush>
                                                            </Border.Background>
                                                            <Grid Margin="10,20,10,8">
                                                                <TextBlock Text="{Binding Title}"
                                                                   Foreground="White"
                                                                   FontWeight="Bold"
                                                                   FontSize="13"
                                                                   TextWrapping="Wrap"
                                                                   VerticalAlignment="Bottom"/>
                                                                <TextBlock Text="&#x29C9;"
                                                                   Foreground="White"
                                                                   FontSize="14"
                                                                   HorizontalAlignment="Right"
                                                                   VerticalAlignment="Bottom"/>
                                                            </Grid>
                                                        </Border>
                                                    </Grid>
                                                </Border>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>

                        </Grid>

                        <TextBlock Text="Blog"
                           FontSize="18"
                           FontWeight="Bold"
                           Foreground="White"
                           Margin="5,0,0,10"/>

                        <Border Height="2" Background="#F5A623" Margin="5,0,0,10"/>

                        <ItemsControl ItemsSource="{Binding BlogItems}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="3" HorizontalAlignment="Stretch"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Command="{Binding DataContext.ItemClickCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                        CommandParameter="{Binding Link}"
                        Background="Transparent"
                        BorderThickness="0"
                        Padding="0"
                        Cursor="Hand">
                                        <Border Margin="6"
                            Background="#2D2D2D"
                            CornerRadius="6"
                            ClipToBounds="True">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#2D2D2D"/>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#3A3A3A"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="180"/>
                                                    <RowDefinition Height="*"/>
                                                </Grid.RowDefinitions>

                                                <Border Grid.Row="0"
                                    Background="#1F1F1F"
                                    ClipToBounds="True">
                                                    <Image Source="{Binding Image}"
                                       Stretch="UniformToFill"/>
                                                </Border>

                                                <StackPanel Grid.Row="1"
                                        Margin="14,12,14,14">
                                                    <TextBlock Text="{Binding Title}"
                                           Foreground="White"
                                           FontWeight="Bold"
                                           FontSize="15"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,8"/>
                                                    <TextBlock Text="{Binding Description}"
                                           Foreground="#AAAAAA"
                                           FontSize="12"
                                           TextWrapping="Wrap"
                                           MaxHeight="80"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                    </StackPanel>
            </StackPanel>

        </ScrollViewer>
        
    </Grid>
</Page>
