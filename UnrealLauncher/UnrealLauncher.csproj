<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net9.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
  </PropertyGroup>

  <ItemGroup>
    <None Remove="Data\Image\Library\EngineVersionLogo.png" />
    <None Remove="UserControlViews\Library\EngineVersionLogo.png" />
  </ItemGroup>

  <ItemGroup>
    <Content Include="Data\Image\Library\EngineVersionLogo.png">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>

  <ItemGroup>
    <Resource Include="UserControlViews\Library\EngineVersionLogo.png" />
  </ItemGroup>

</Project>
